
include "soundsystem/soundsystem.h"
include "soundsystem/mp3_helpers.h"

[small]
native struct AudioDeviceDesc is NativeEngine.AudioDeviceDesc;


native accessor g_pSoundSystemInternal as g_pSoundSystem
{
	int GetNumAudioDevices();
	AudioDeviceDesc GetAudioDeviceDesc( int index );
	string GetAudioDeviceId( int index );
	string GetAudioDeviceName( int index );
	string GetActiveAudioDevice();
	void SetActiveAudioDevice( string id );
	void PlaySoundAtOSLevel( string filename );

	CSfxTable PrecacheSound( string pSoundName );
	CSfxTable CreateSound( string pSoundName, int nChannels, int nRate, int nFormat, int nSampleCount, float flDuration, int nLoopStart, int nLoopEnd, void* pData, int nDataSize );
	void PreloadSound( CSfxTable pSfx );
}

native class CSimplePCMWaveData
{
	static CSimplePCMWaveData Create();[new]
	void Dispose(); [delete]

	void ParseMP3File( CastTo[uint8*] void* pData, CastTo[size_t] int nDataSize );	
	bool ParseOGGFile( CastTo[uint8*] void* pData, CastTo[size_t] int nDataSize );	

	inline void* GetPCMData()
	{
		return self->m_pcmData.Base();
	}

	inline int GetPCMSize()
	{
		return self->m_pcmData.TellMaxPut();
	}

	uint m_nFormat;
	uint m_nSampleRate;
	uint m_nChannels;
	uint m_nSampleCount;
	uint m_nBits;
	float m_flDuration;
}
