@using MenuProject
@using Sandbox;
@using Sandbox.UI;
@using Sandbox.UI.Navigation;
@namespace Sandbox.UI
@inherits Panel

@if (def == null)
    return;

@{
    var daysActive = (DateTimeOffset.UtcNow - Sandbox.MenuEngine.Account.FirstSeen).TotalDays;
    if ( daysActive < 14 ) return;

    // Only nag about it once it's actually leaving soon
    if ( DaysLeft >= 3 ) return;

    var daysLeftString = DaysLeft == 0 ? "today!" : DaysLeft == 1 ? $"in 1 day" : $"in {DaysLeft} days";
}

<root>
    <Button class="hide" Icon="close" @onmousedown=@(() => Enabled = false)></Button>
    <icon class="triangle">
        arrow_left
    </icon>
    <div class="cta">Leaving @daysLeftString</div>
    <Button class="item clicky" Icon="@def.IconUrl" Text="@def.Name" @onmousedown=@OpenStore></Button>
</root>

@code {
    public bool ComputedVisibility
    {
        get
        {
            return this.GetNavigator()?.CurrentUrlMatches("/home") ?? false;
        }
    }

    private static bool Enabled = true;

    public DateTimeOffset EndTime { get; set; } = DateTimeOffset.FromUnixTimeSeconds(1767258000);
    public int DaysLeft => (int)Math.Floor((def.SellEnd.Value - DateTimeOffset.UtcNow).TotalDays);

    Sandbox.Services.Inventory.ItemDefinition def;

    protected override void OnParametersSet()
    {
        def = Sandbox.Services.Inventory.Definitions
                .Where(x => x.SellEnd.HasValue) // is going to stop selling
                .Where(x => x.SellEnd.Value > DateTimeOffset.UtcNow) // is currently for sale
                .Where(x => x.SellStart.HasValue) // has a start time
                .Where(x => x.SellStart.Value < DateTimeOffset.UtcNow) // has started to be for sale
                .Where(x => !Sandbox.Services.Inventory.HasItem(x.Id)) // we don't own it
                .OrderBy(x => Guid.NewGuid()) // random item
                .FirstOrDefault();

        Enabled = true;

        base.OnParametersSet();
    }

    public override void Tick()
    {
        SetClass("enabled", Enabled && ComputedVisibility);
    }

    void OpenStore()
    {
        this.Navigate( "/itemstore" );
    }

    // Include inventory count in hash so the UI updates after purchases
    protected override int BuildHash() => HashCode.Combine(Enabled, def?.Id, Sandbox.Services.Inventory.Items?.Count, ComputedVisibility);
}
