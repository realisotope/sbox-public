@using Sandbox.Modals
@using Sandbox
@using Sandbox.Network
@using Sandbox.UI

<root>
    @if ( busy )
    {
        <div class="loading">
            <Spinner/>
        </div>
    }
    else if ( viewMode == ViewMode.GameGroup )
    {
        @if ( gameGroups.Count == 0 )
        {
            <div class="notice">Sorry - no servers were found 😔</div>
        }
        else
        {
            <VirtualList Items=@(gameGroups.Cast<object>()) ItemHeight=@(56)>
                <Item Context="item">
                    @if ( item is GameGroup group )
                    {
                        <GameGroupRow GameIdent="@group.GameIdent"
                                      TotalPlayers="@group.TotalPlayers"
                                      ServerCount="@group.ServerCount"
                                      OnGroupClick="@(() => ScopeToGame( group ))" />
                    }
                </Item>
            </VirtualList>
        }
    }
    else
    {
        @if ( scopedGame is not null )
        {
            <GameGroupRow GameIdent="@scopedGroup.GameIdent"
                          TotalPlayers="@scopedGroup.TotalPlayers"
                          ServerCount="@scopedGroup.ServerCount"
                          OnGroupClick=@BackToGames>
                            <Left>
            @if (string.IsNullOrWhiteSpace(Config.GamePackageFilter))
            {
                <i>arrow_back</i>
            }
            </Left>
            </GameGroupRow>
        }

        @if ( serverLobbies.Count == 0 )
        {
            <div class="notice">Sorry - no servers were found 😔</div>
        }
        else
        {
            <div class="header row">
                <h2 class="title" onclick="@(() => SetSort( "name" ))">Name</h2>
                <h2 class="map" onclick="@(() => SetSort( "map" ))">Map</h2>
                <h2 class="members" onclick="@(() => SetSort( "members" ))">Players</h2>
                <h2 class="ping-icon" />
                <h2 class="ping-value" onclick="@(() => SetSort("ping"))">Ping</h2>
            </div>
            <VirtualList Items=@GetServerData() ItemHeight=@(48)>
                <Item Context="item">
                    @if ( item is LobbyInformation lobby )
                    {
                        <ServerRow Server="@lobby"></ServerRow>
                    }
                </Item>
            </VirtualList>
        }
    }
</root>

@code
{
    enum ViewMode { GameGroup, ServerList }

    record GameGroup( string GameIdent, int TotalPlayers, int ServerCount );

    [Parameter]
    public ServerListConfig Config { get; set; } = default;

    /// <summary>
    /// Opportunity to filter the shown list of servers
    /// </summary>
    [Parameter] public Func<LobbyInformation, bool> Filter { get; set; }

    bool busy;
    List<LobbyInformation> lobbies = new();

    string sortBy;
    bool sortDescending;

    ViewMode viewMode;
    string scopedGame;
    GameGroup scopedGroup;

    List<LobbyInformation> filteredLobbies => lobbies is null ? [] :
        Filter is not null
            ? lobbies.Where( Filter ).ToList()
            : lobbies;

    List<GameGroup> gameGroups => filteredLobbies
        .GroupBy( x => x.Game )
        .Select( g => new GameGroup( g.Key, g.Sum( x => x.Members ), g.Count() ) )
        .OrderByDescending( g => g.TotalPlayers )
        .ToList();

    List<LobbyInformation> serverLobbies
    {
        get
        {
            var source = scopedGame is not null
                ? filteredLobbies.Where( x => x.Game == scopedGame )
                : filteredLobbies;

            return ApplySort( source ).ToList();
        }
    }

    IEnumerable<object> GetServerData() => serverLobbies.Cast<object>();

    IEnumerable<LobbyInformation> ApplySort( IEnumerable<LobbyInformation> source )
    {
        if ( sortBy is null )
            return source.OrderByDescending( x => x.Members );

        Func<LobbyInformation, object> key = sortBy switch
        {
            "name" => x => x.Name,
            "map" => x => x.Map,
            "members" => x => x.Members,
            "ping" => x => x.Ping,
            _ => x => x.Members
        };

        return sortDescending
            ? source.OrderByDescending( key )
            : source.OrderBy( key );
    }

    void SetSort( string column )
    {
        if ( sortBy == column )
            sortDescending = !sortDescending;
        else
        {
            sortBy = column;
            sortDescending = false;
        }

        StateHasChanged();
    }

    void ScopeToGame( GameGroup group )
    {
        scopedGame = group.GameIdent;
        scopedGroup = group;
        viewMode = ViewMode.ServerList;
        StateHasChanged();
    }

    void BackToGames()
    {
        if (!string.IsNullOrEmpty(Config.GamePackageFilter) )
            return; // single-game enforced

        scopedGame = null;
        scopedGroup = null;
        viewMode = ViewMode.GameGroup;
        StateHasChanged();
    }

    protected override async Task OnParametersSetAsync()
    {
        // If an external game filter is applied, skip the grouped view
        viewMode = string.IsNullOrEmpty( Config.GamePackageFilter )
            ? ViewMode.GameGroup
            : ViewMode.ServerList;

        scopedGame = null;
        scopedGroup = null;

        await RefreshLobbies();
    }

    public async Task RefreshLobbies()
    {
        lobbies = default;
        StateHasChanged();

        busy = true;

        var filters = new Dictionary<string, string>
        {
            { "game", Config.GamePackageFilter },
            { "map", Config.MapPackageFilter },
        };

        lobbies = await Networking.QueryLobbies( filters );

        busy = false;

        if (viewMode == ViewMode.ServerList && !string.IsNullOrWhiteSpace(Config.GamePackageFilter))
        {
            scopedGame = Config.GamePackageFilter;
            scopedGroup = new GameGroup( Config.GamePackageFilter, lobbies.Sum(x => x.Members), lobbies.Count );
        }

        StateHasChanged();
    }
}
