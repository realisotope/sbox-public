@using Sandbox;
@using Sandbox.UI;
@using MenuProject.UI;
@using Menu;
@inherits Panel

<root class="cblock">
	<ContentBlockHeader Group="@Group"></ContentBlockHeader>
	<ContentBlockBody>
		<ChildContent>
			@foreach ( var package in Group.Packages )
			{
				<PackageCard Package=@package Clicked="@(() => package.OpenModal())" RightClicked="@(() => MenuHelpers.OpenPackageMenu(this, package))" />
			}
		</ChildContent>
	</ContentBlockBody>
</root>

@code
{
    [Parameter]
    public Package.ListResult.Grouping Group { get; set; }
}
