@using Sandbox;
@using Sandbox.UI;
@inherits Panel

<root></root>

@code
{
    record struct Entry(Panel Content, float Duration, bool ClickToDismiss, RealTimeSince Since);

    readonly Queue<Entry> PendingQueue = new();
    readonly List<Entry> ShownPanels = new();

    /// <summary>
    /// Queues a simple toast with a title, message, and icon.
    /// </summary>
    public Panel QueueToast(string title, string message, string icon = null, float duration = 4f)
    {
        var toast = new Toast()
        {
            Title = title,
            Message = message,
            Icon = icon
        };

        return Queue(toast, duration);
    }

    /// <summary>
    /// Show a panel immediately, dismissing any previously shown panels.
    /// </summary>
    public Panel Show(Panel content, float duration = 4f, bool clickToDismiss = true)
    {
        // Dismiss all existing shown panels
        for (int i = ShownPanels.Count - 1; i >= 0; i--)
        {
            Dismiss(ShownPanels[i].Content);
        }

        if (content is Toast toast)
            toast.Area = this;

        Display(new Entry(content, duration, clickToDismiss, 0));

        return content;
    }

    /// <summary>
    /// Queue a panel to be shown. Queued panels are shown one at a time, in sequence - the
    /// next one only appears once the current one has been dismissed.
    /// Setting duration to 0 means it's up to you to remove it manually.
    /// </summary>
    public Panel Queue(Panel content, float duration = 4f, bool clickToDismiss = true)
    {
        if (content is Toast toast)
            toast.Area = this;

        PendingQueue.Enqueue(new Entry(content, duration, clickToDismiss, 0));
        ShowNext();

        return content;
    }

    public override void Tick()
    {
        base.Tick();

        for (int i = ShownPanels.Count - 1; i >= 0; i--)
        {
            var entry = ShownPanels[i];
            if (entry.Duration > 0 && entry.Since >= entry.Duration)
                Dismiss(entry.Content);
        }

        ShowNext();
    }

    /// <summary>
    /// Show the next queued panel, but only once nothing is currently on screen.
    /// </summary>
    void ShowNext()
    {
        if (ShownPanels.Count > 0)
            return;

        while (PendingQueue.Count > 0)
        {
            var entry = PendingQueue.Dequeue();

            // Skip anything that was deleted while it was waiting in the queue.
            if (!entry.Content.IsValid())
                continue;

            Display(entry);
            return;
        }
    }

    /// <summary>
    /// Parent a panel into the area and start its dismissal timer.
    /// </summary>
    void Display(Entry entry)
    {
        // Reset the timer - duration shouldn't count time spent waiting in the queue.
        entry = entry with { Since = 0 };

        ShownPanels.Add(entry);
        entry.Content.Parent = this;

        if (entry.ClickToDismiss)
            entry.Content.AddEventListener("onmousedown", () => Dismiss(entry.Content));
    }

    /// <summary>
    /// Dismiss a specific panel.
    /// </summary>
    public void Dismiss(Panel panel)
    {
        if (!panel.IsValid()) return;

        ShownPanels.RemoveAll(e => e.Content == panel);
        panel.Delete();
    }
}
