@using Sandbox.UI;
@using Sandbox.UI.Navigation;
@using Sandbox;
@using System;
@using Menu;
@using MenuProject.Modals;
@inherits PanelComponent

<div class="mainmenu">

    <NavigationHost DefaultUrl="/home" @ref="Navigator">
        <ChildContent>

            <Navbar />

            <div class="navigator-canvas" slot="navigator-canvas"></div>
			<div class="overlay">
				<div class="overlay-container">
					<OfflineMode />
				</div>
			</div>

            <Footer />

        </ChildContent>
    </NavigationHost>
</div>

@code
{
    [Property] public GameObject Background { get; set; }
    public NavigationHost Navigator { get; protected set; }

    public static MainMenu Instance { get; private set; }

    static bool _welcomeShown;

    override protected void OnEnabled()
    {
        base.OnEnabled();

        Instance = this;

        var human = Scene.Directory.FindByName("Player Human").FirstOrDefault();
        var citizen = Scene.Directory.FindByName("Player Citizen").FirstOrDefault();
        var clothing = ClothingContainer.CreateFromLocalUser();

        if ( human.IsValid() )
            human.Enabled = clothing.PrefersHuman;

        if ( citizen.IsValid() )
            citizen.Enabled = !clothing.PrefersHuman;

        // Fetch resolutions now so opening the settings modal doesn't stutter later.
        MenuProject.Settings.VideoSettings.FetchResolutions();

        _ = ShowWelcomeScreenIfNeeded();
    }

    async Task ShowWelcomeScreenIfNeeded()
    {
        await Task.DelayRealtime(1500);

        if ( _welcomeShown ) return;
        if ( Game.Cookies.Get<bool>( WelcomeScreenModal.CookieKey, false ) ) return;

        _welcomeShown = true;

        var modal = new WelcomeScreenModal();
        modal.Parent = Panel;
    }

    override protected void OnUpdate()
    {
        SetClass( "is-vr", Application.IsVR );
        SetClass( "has-streamer-account", Sandbox.MenuEngine.Account.HasLinkedStreamerServices );

        var isInGame = Application.IsEditor ? false : Game.InGame;
        Background.Enabled = Navigator?.CurrentUrl == "/home" && !isInGame;
    }
}
