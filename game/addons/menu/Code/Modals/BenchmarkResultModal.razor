@using Menu
@using Sandbox
@using Sandbox.Modals
@using Sandbox.UI

@namespace MenuProject.Modals
@inherits MenuProject.Modals.BaseModal

<root>
    <div class="window">

        <div class="header">
            <i>speed</i>
            <label class="title">Benchmark Results</label>
            <Button class="close-btn" onclick=@(() => CloseModal( true ))><i>close</i></Button>
        </div>

        <div class="summary-cards">
            <StatCard Icon="emoji_events" Value=@OverallScoreText Subtitle="Overall Score" />
            <StatCard Icon="speed"        Value=@AvgFpsText        Subtitle="Avg FPS" />
            <StatCard Icon="checklist"    Value=@TestCountText     Subtitle="Tests" />
            <StatCard Icon="timer"        Value=@DurationText      Subtitle="Duration" />
        </div>

        <div class="test-table">

            <div class="test-row header-row">
                <label class="col-name">Test</label>
                <label class="col-num">Avg FPS</label>
                <label class="col-num">Frame ms</label>
                <label class="col-num">1% Low ms</label>
                <label class="col-num">GPU ms</label>
                <label class="col-num">Stutter</label>
            </div>

            @foreach ( var t in Summaries )
            {
                <div class="test-row">
                    <label class="col-name">@t.Name</label>
                    <label class="col-num">@t.AvgFps.ToString( "F1" )</label>
                    <label class="col-num">@t.AvgFrameTimeMs.ToString( "F2" )</label>
                    <label class="col-num">@t.OnePercentLowMs.ToString( "F2" )</label>
                    <label class="col-num">@t.AvgGpuFrametimeMs.ToString( "F2" )</label>
                    <label class="col-num">@t.Stuttering.ToString( "F1" )</label>
                </div>
            }

        </div>

        <div class="footer">
            <Button class="primary" Icon="open_in_new" onclick=@ViewOnline>View Online</Button>
        </div>

    </div>
</root>

@code
{
    public Guid BatchId { get; }
    public IReadOnlyList<BenchmarkTestSummary> Summaries { get; }

    public BenchmarkResultModal( Guid batchId, IReadOnlyList<BenchmarkTestSummary> summaries )
    {
        BatchId = batchId;
        Summaries = summaries ?? Array.Empty<BenchmarkTestSummary>();
    }

    double OverallScore
    {
        get
        {
            if ( Summaries.Count == 0 ) return 0;
            var logSum = Summaries.Sum( t => Math.Log( Math.Max( t.AvgFps, 0.001 ) ) );
            return Math.Exp( logSum / Summaries.Count );
        }
    }

    string OverallScoreText => OverallScore.ToString( "F0" );
    string AvgFpsText       => Summaries.Count > 0 ? Summaries.Average( t => t.AvgFps ).ToString( "F1" ) : "—";
    string TestCountText    => Summaries.Count.ToString();
    string DurationText     => TimeSpan.FromSeconds( Summaries.Sum( t => t.DurationSeconds ) ).ToString( @"m\:ss" );

    void ViewOnline()
    {
        var url = BatchId != Guid.Empty
            ? $"https://sbox.game/benchmarks/view/{BatchId}"
            : "https://sbox.game/benchmarks";
        MenuUtility.OpenUrl( url );
    }
}
